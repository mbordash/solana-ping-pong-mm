# Solana RPC Configuration
MNEMONIC="your-bip39-mnemonic-seed-phrase-here"
HELIUS_RPC="https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY"

# Backend Server
PORT=3001
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=your-secure-dashboard-password

# CORS Configuration
# List comma-separated origins that are allowed to access the backend API
# Example: http://localhost:3000,http://myapp.com:3000,https://myapp.com
ALLOWED_ORIGINS=http://localhost:3000

# Frontend Configuration (passed to Docker build)
FRONTEND_API_URL=http://localhost:3001/api
FRONTEND_API_PASSWORD=your-secure-dashboard-password
