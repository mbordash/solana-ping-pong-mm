services:
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: ping-pong-mm-backend
    restart: always
    env_file:
      - .env
    environment:
      # IMPORTANT: Set ALLOWED_ORIGINS to your frontend URL for CORS to work
      # This value comes from .env file (ALLOWED_ORIGINS variable)
      - ALLOWED_ORIGINS=${ALLOWED_ORIGINS:-http://localhost:3000}
      # Dashboard password comes from .env (BASIC_AUTH_PASS variable)
      - BASIC_AUTH_PASS=${BASIC_AUTH_PASS}
    ports:
      - "3001:3001"
    networks:
      - mmnet

  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
      args:
        # Backend API URL that the frontend connects to
        # This value comes from .env file (FRONTEND_API_URL variable)
        - NEXT_PUBLIC_API_URL=${FRONTEND_API_URL:-http://localhost:3001/api}
        # Dashboard password - comes from .env (FRONTEND_API_PASSWORD variable)
        - NEXT_PUBLIC_API_PASSWORD=${FRONTEND_API_PASSWORD}
    container_name: ping-pong-mm-frontend
    restart: always
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
    networks:
      - mmnet

networks:
  mmnet:
    driver: bridge

